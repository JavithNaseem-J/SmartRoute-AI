# LLM ───────────────────────────────────────────────────────────
# Free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# API Authentication ────────────────────────────────────────────
# CHANGE THIS to a strong random string before deploying
# All /query, /stats, /budget, /models endpoints require X-API-Key header.
SMARTROUTE_API_KEY=dev-key-change-in-production

# Supabase — PostgreSQL Database ────────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Upstash — Redis (Budget + Session Memory) ─────────────────────
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[your-endpoint].upstash.io:6379

# Qdrant Cloud — Vector Database ─────────────────────────────────
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here


# Budget Limits (USD) ───────────────────────────────────────────
DAILY_BUDGET=10.0
WEEKLY_BUDGET=50.0
MONTHLY_BUDGET=200.0


# LangFuse — LLM Tracing & Observability ────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel

