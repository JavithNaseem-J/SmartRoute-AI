# ─────────────────────────────────────────────────────────────────────────────
# SmartRoute-AI — Cloud Environment Configuration
# Copy this file to .env and fill in ALL required values.
# NEVER commit .env to git (it is already in .gitignore).
#
# This app runs entirely in the cloud. No local database or local storage.
# Three cloud services are REQUIRED before the app will start:
#   1. Groq          → LLM inference (free)
#   2. Supabase      → PostgreSQL database (free 500MB)
#   3. Upstash       → Redis cache & budget (free 10K req/day)
#   4. Qdrant Cloud  → Vector database (free 1GB)
# ─────────────────────────────────────────────────────────────────────────────

# ── [REQUIRED] LLM ───────────────────────────────────────────────────────────
# Free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── [REQUIRED] API Authentication ────────────────────────────────────────────
# CHANGE THIS to a strong random string before deploying.
# All /query, /stats, /budget, /models endpoints require X-API-Key header.
SMARTROUTE_API_KEY=dev-key-change-in-production

# ── [REQUIRED] Supabase — PostgreSQL Database ────────────────────────────────
# 1. Create free project at https://supabase.com
# 2. Project Settings → Database → Connection string → URI (mode: Session)
# 3. Replace [YOUR-PASSWORD] with your database password
#
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── [REQUIRED] Upstash — Redis (Budget + Session Memory) ─────────────────────
# 1. Create free database at https://upstash.com
# 2. Go to your database → Details → Redis URL (starts with rediss://)
#
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[your-endpoint].upstash.io:6379

# ── [REQUIRED] Qdrant Cloud — Vector Database ─────────────────────────────────
# 1. Create free cluster at https://cloud.qdrant.io
# 2. Copy Cluster URL from the cluster overview page
# 3. Generate API key under the cluster's API Keys tab
#
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# ── [OPTIONAL] Budget Limits (USD) ───────────────────────────────────────────
DAILY_BUDGET=10.0
WEEKLY_BUDGET=50.0
MONTHLY_BUDGET=200.0

# ── [OPTIONAL] CORS ───────────────────────────────────────────────────────────
# Add your Streamlit Cloud / Render frontend URL here after deployment
ALLOWED_ORIGINS=https://smartroute-ai.streamlit.app,http://localhost:8501

# ── [OPTIONAL] LangFuse — LLM Tracing & Observability ────────────────────────
# Free dashboard showing every LLM call: latency, cost, input/output, sessions.
# 1. Create free project at https://cloud.langfuse.com
# 2. Go to Settings → API Keys → Create new key pair
# 3. Set both keys below — tracing activates automatically
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LangFuse OTEL endpoint — do not change this value
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel

# ── [OPTIONAL] OpenTelemetry Tracing ─────────────────────────────────────────
# Leave blank to disable. Set to Honeycomb/Axiom endpoint for observability.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smartroute-ai
ENVIRONMENT=production
