# ─────────────────────────────────────────────────────────────────────────────
# SmartRoute-AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# Required. Free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── API Authentication ────────────────────────────────────────────────────────
# CHANGE THIS before any public deployment.
# All /query, /stats, /budget, /models endpoints require X-API-Key header.
# / and /health are public (used by load-balancer health probes).
SMARTROUTE_API_KEY=dev-key-change-in-production

# ── Budget Limits (USD) ───────────────────────────────────────────────────────
DAILY_BUDGET=10.0
WEEKLY_BUDGET=50.0
MONTHLY_BUDGET=200.0

# ── Database (Phase 3 Enterprise Upgrade) ─────────────────────────────────────
# Leave blank → uses local SQLite (fine for development / single-node).
#
# SUPABASE (recommended — free 500 MB PostgreSQL):
#   1. Create project at https://supabase.com
#   2. Go to Project Settings → Database → Connection string → URI
#   3. Paste below (replace [YOUR-PASSWORD] with your DB password):
#
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Redis Cache & Budget Counter (Phase 3 Enterprise Upgrade) ─────────────────
# Leave blank → falls back to in-memory (single-node only, breaks multi-worker).
#
# UPSTASH REDIS (recommended — free 10,000 req/day, zero ops, serverless):
#   1. Create database at https://upstash.com
#   2. Go to your database → Details → REST URL / Redis URL
#   3. Use the "Redis URL" (starts with rediss://):
#
# REDIS_URL=rediss://default:[YOUR-PASSWORD]@[your-endpoint].upstash.io:6379
REDIS_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── OpenTelemetry Tracing (optional) ─────────────────────────────────────────
# Leave blank to disable tracing entirely (zero overhead).
# Set to your OTLP endpoint (Jaeger, Tempo, Honeycomb, Axiom, Datadog):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smartroute-ai
ENVIRONMENT=production
