GROQ_API_KEY=your-groq-api-key-here

# API Authentication — CHANGE THIS before any public deployment.
# All data endpoints (/query, /stats, /savings, /budget, /models, /strategy)
# require this key in the X-API-Key header. / and /health are public (k8s probes).
SMARTROUTE_API_KEY=dev-key-change-in-production

# Cost Budgets (USD)
DAILY_BUDGET=10.0
WEEKLY_BUDGET=50.0
MONTHLY_BUDGET=200.0

# Database — leave unset to use SQLite (development/single-node)
# Set to a PostgreSQL URL for production horizontal scaling:
# DATABASE_URL=postgresql://user:password@host:5432/smartroute
DATABASE_URL=

# Redis — optional, for atomic distributed budget enforcement across workers.
# Leave unset to use SQLite-based budget tracking (single-node only).
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# OpenTelemetry — leave unset to disable tracing (zero overhead).
# Set OTEL_EXPORTER_OTLP_ENDPOINT to send traces to Jaeger, Tempo, or Datadog.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smartroute-ai
ENVIRONMENT=production
