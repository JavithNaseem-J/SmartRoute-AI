{
  "name": "SmartRoute-AI",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.10-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "updateContentCommand": "pip install -r requirements.txt -r requirements-dev.txt",
  "postAttachCommand": {
    "api": "uvicorn api.main:app --reload --host 0.0.0.0 --port 8000",
    "dashboard": "streamlit run app.py --server.port 8501 --server.headless true"
  },
  "portsAttributes": {
    "8000": {
      "label": "FastAPI Backend",
      "onAutoForward": "notify"
    },
    "8501": {
      "label": "Streamlit Dashboard",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8000, 8501]
}